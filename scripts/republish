#!/usr/bin/env bash
# Run the full published demonstration suite.
#
# Usage:
#   scripts/republish                    # run everything (claude via hunt-local)
#   scripts/republish smoke              # smoke tier only
#   scripts/republish applied            # swept applied tier only
#   scripts/republish formalize-hunt     # 6 demonstration targets only
#
# Runs use hunt-local (no Docker, host Claude OAuth).
# Results are copied into runs/published/ after each run.
set -u

cd "$(dirname "$0")/.."

SUITE="${1:-all}"
HUNT="./scripts/hunt-local"
PUBLISHED="runs/published"
FAILED=()
RAN=0

run_and_publish() {
    local target="$1"
    local mode="$2"
    local cycles="$3"
    local dest="$4"

    local name
    name="$(basename "$target")"

    echo
    echo "===== $name --mode $mode --cycles $cycles ====="

    $HUNT "$target" --mode "$mode" --cycles "$cycles" 2>&1
    local rc=$?

    # Find the run that was just created
    local run_dir
    run_dir=$(ls -dt runs/*-${name}-claude-local 2>/dev/null | head -1)

    if [[ -z "$run_dir" || ! -d "$run_dir" ]]; then
        echo "  WARNING: no run directory found for $name"
        FAILED+=("$name/$mode")
        return 1
    fi

    # Copy essentials to published location
    mkdir -p "$dest"
    cp "$run_dir/run.json" "$dest/" 2>/dev/null
    mkdir -p "$dest/artifacts"
    cp "$run_dir/artifacts/findings.json" "$dest/artifacts/" 2>/dev/null
    cp "$run_dir/artifacts/notes.md" "$dest/artifacts/" 2>/dev/null
    cp "$run_dir/artifacts/threat-model.md" "$dest/artifacts/" 2>/dev/null
    cp "$run_dir/artifacts/spec-trace.md" "$dest/artifacts/" 2>/dev/null
    cp "$run_dir/artifacts/hypotheses.md" "$dest/artifacts/" 2>/dev/null
    cp "$run_dir/artifacts/divergences.md" "$dest/artifacts/" 2>/dev/null

    # Copy lean/sage state if it exists. Flatten the inner .git
    # (the agent's per-cycle commit history) into a plain git-history.log
    # alongside the contents so the outer harness repo can track the state
    # as regular files instead of as a gitlink/embedded-repo.
    if [[ -d "$target/state" ]]; then
        mkdir -p "$dest/state"
        if [[ -d "$target/state/.git" ]]; then
            git -C "$target/state" log --oneline > "$dest/state/git-history.log" 2>/dev/null || true
        fi
        # rsync preserves structure; --exclude .git drops the embedded repo.
        rsync -a --exclude='.git' --exclude='.lake-cache' \
            "$target/state/" "$dest/state/"
    fi

    local nf=0
    if [[ -f "$dest/artifacts/findings.json" ]]; then
        nf=$(python3 -c "import json; print(len(json.load(open('$dest/artifacts/findings.json')).get('findings',[])))" 2>/dev/null || echo 0)
    fi

    echo "  -> $nf findings, published to $dest"
    RAN=$((RAN + 1))

    if [[ $rc -ne 0 ]]; then
        FAILED+=("$name/$mode (rc=$rc)")
    fi
}

# ---------------------------------------------------------------
# Smoke sweep: all 17 targets, hunt mode, 3 cycles each
# ---------------------------------------------------------------
if [[ "$SUITE" == "all" || "$SUITE" == "smoke" ]]; then
    echo "=============================="
    echo "  SMOKE SWEEP (17 targets)"
    echo "=============================="
    for target in targets/smoke/smoke-*/; do
        name=$(basename "$target")
        run_and_publish "$target" hunt 3 "$PUBLISHED/smoke-sweep/$name"
    done
fi

# ---------------------------------------------------------------
# Applied sweep: 21 swept targets, hunt mode, 5 cycles each
# ---------------------------------------------------------------
if [[ "$SUITE" == "all" || "$SUITE" == "applied" ]]; then
    echo "=============================="
    echo "  APPLIED SWEEP (swept targets)"
    echo "=============================="
    for target in targets/applied/applied-*/; do
        name=$(basename "$target")
        # Skip unswept targets (they're in formalize-hunt)
        if grep -q "Not yet swept" "$target/HUMANS.md" 2>/dev/null; then
            continue
        fi
        run_and_publish "$target" hunt 5 "$PUBLISHED/applied-sweep/$name"
    done
fi

# ---------------------------------------------------------------
# Formalize-hunt: 6 targets, formalize then hunt, 5 cycles each
# ---------------------------------------------------------------
if [[ "$SUITE" == "all" || "$SUITE" == "formalize-hunt" ]]; then
    echo "=============================="
    echo "  FORMALIZE-HUNT (6 targets)"
    echo "=============================="

    DEMO_TARGETS=(
        "targets/applied/applied-03"
        "targets/applied/applied-04"
        "targets/applied/applied-05"
        "targets/applied/applied-16"
        "targets/applied/applied-21"
        "targets/applied/applied-33"
    )

    for target in "${DEMO_TARGETS[@]}"; do
        name=$(basename "$target")
        bug=$(sed -n 's/.*bug-class name:\*\* `\(.*\)`/\1/p' "$target/HUMANS.md" 2>/dev/null)
        dest_base="$PUBLISHED/formalize-hunt/$name-$bug"

        # Initialize state dir for cumulative Lean model
        mkdir -p "$target/state/lean" "$target/state/sage"
        if [[ ! -d "$target/state/.git" ]]; then
            git -C "$target/state" init -q 2>/dev/null
        fi

        # Phase 1: formalize
        run_and_publish "$target" formalize 5 "$dest_base/formalize-claude"

        # Phase 2: hunt (benefits from formalize's state)
        run_and_publish "$target" hunt 5 "$dest_base/hunt-claude"
    done
fi

# ---------------------------------------------------------------
# Summary
# ---------------------------------------------------------------
echo
echo "=============================="
echo "  SUMMARY"
echo "=============================="
echo "  Ran: $RAN"
echo "  Failed: ${#FAILED[@]}"
for f in "${FAILED[@]}"; do
    echo "    - $f"
done
