#!/usr/bin/env bash
# Defensive: scan a run directory for accidental API key leakage.
set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 <run-dir>" >&2
    exit 1
fi

DIR="$1"

PATTERNS=(
    "sk-ant-[A-Za-z0-9_-]{20,}"
    "sk-proj-[A-Za-z0-9_-]{20,}"
    "sk-[A-Za-z0-9]{40,}"
)

FOUND=0
for pat in "${PATTERNS[@]}"; do
    if grep -rEl "$pat" "$DIR" 2>/dev/null; then
        FOUND=1
    fi
done

if [[ $FOUND -eq 1 ]]; then
    echo "ERROR: API key pattern found in $DIR. Inspect and remove before sharing." >&2
    exit 1
fi
